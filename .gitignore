# General .gitignore for Kubernetes Certification Project

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.vim/
.emacs.d/
*.sublime-*

# Temporary files
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node.js (if any JavaScript tools are used)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if any Python scripts are used)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt

# Go (if any Go code is used)
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
*.coverprofile
profile.cov
vendor/
go.work
go.work.sum

# Kubernetes specific
kubeconfig*
*.kubeconfig
secrets/
*.crt
*.key
*.pem

# CKA lab output directories
cka/1/course/
cka/2/course/
cka/3/course/
cka/4/course/
cka/27/course/
cka/28/course/
cka/31/course/

cka/32/course/
cka/33/course/
cka/34/course/
cka/35/course/
cka/36/course/
cka/7/course/
cka/9/course/
cka/5/course/
cka/16/course/
cka/17/course/
cka/20/course/
cka/26/course/
cka/29/course/

# Documentation build artifacts
_build/
.doctrees/

# Backup files
*.bak
*.backup
*.old

# Archive files
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Personal notes and drafts
notes/
drafts/
personal/
*.draft

# Cache directories
.cache/
.npm/
.yarn/
cka/14/course/
